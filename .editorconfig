root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,sh,yml}]
indent_size = 2
indent_style = space

[*.md]
indent_size = 2
indent_style = space
trim_trailing_whitespace = false

[*.patch]
trim_trailing_whitespace = false

[{.pre-commit-config.yaml,Dockerfile}]
indent_size = 4
indent_style = space
